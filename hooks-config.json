{
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "node \"${LAZY_CLAUDECODE_ROOT}/dist/hooks/bootstrap.js\"", "timeout": 30 }] },
      { "hooks": [{ "type": "command", "command": "node \"${LAZY_CLAUDECODE_ROOT}/dist/hooks/rules-loader.js\"", "timeout": 10 }] },
      { "hooks": [{ "type": "command", "command": "node \"${LAZY_CLAUDECODE_ROOT}/dist/hooks/telemetry.js\"", "timeout": 5 }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "node \"${LAZY_CLAUDECODE_ROOT}/dist/hooks/ultrawork-trigger.js\"", "timeout": 5 }] },
      { "hooks": [{ "type": "command", "command": "node \"${LAZY_CLAUDECODE_ROOT}/dist/hooks/ulw-loop-steering.js\"", "timeout": 5 }] }
    ],
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [{ "type": "command", "command": "node \"${LAZY_CLAUDECODE_ROOT}/dist/hooks/git-bash-reminder.js\"", "timeout": 5 }] }
    ],
    "PostToolUse": [
      { "matcher": "Edit|Write|MultiEdit", "hooks": [
        { "type": "command", "command": "node \"${LAZY_CLAUDECODE_ROOT}/dist/hooks/comment-checker.js\"", "timeout": 30 },
        { "type": "command", "command": "node \"${LAZY_CLAUDECODE_ROOT}/dist/hooks/lsp-diagnostics.js\"", "timeout": 60 },
        { "type": "command", "command": "node \"${LAZY_CLAUDECODE_ROOT}/dist/hooks/codegraph-init.js\"", "timeout": 5 }
      ]}
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "node \"${LAZY_CLAUDECODE_ROOT}/dist/hooks/start-work-continuation.js\"", "timeout": 10 }] }
    ],
    "SubagentStop": [
      { "hooks": [{ "type": "command", "command": "node \"${LAZY_CLAUDECODE_ROOT}/dist/hooks/executor-verify.js\"", "timeout": 10 }] }
    ],
    "PostCompact": [
      { "hooks": [{ "type": "command", "command": "node \"${LAZY_CLAUDECODE_ROOT}/dist/hooks/post-compact-reset.js\"", "timeout": 5 }] }
    ]
  }
}
