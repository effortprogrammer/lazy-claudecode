{
	"name": "lazy-claudecode",
	"version": "0.1.5",
	"description": "Agent harness for Claude Code — hooks, skills, MCP servers, and systematic work modes. Ported from LazyClaude.",
	"type": "module",
	"bin": {
		"lazy-claudecode": "bin/lazy-claudecode.js"
	},
	"scripts": {
		"lint": "biome check src/",
		"lint:fix": "biome check --write src/",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"build": "bun build src/installer/install.ts src/installer/uninstall.ts src/installer/doctor.ts --outdir dist/lib --target node --format esm --no-splitting",
		"prepublishOnly": "bun run build"
	},
	"keywords": [
		"claude",
		"claude-code",
		"hooks",
		"agent",
		"mcp",
		"ai",
		"developer-tools",
		"bun"
	],
	"author": "Hojin Yang",
	"license": "MIT",
	"engines": {
		"bun": ">=1.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/picomatch": "^4.0.3",
		"bun-types": "^1.3.14",
		"typescript": "^5.5.0"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"picomatch": "^4.0.4",
		"posthog-node": "^5.38.5"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/effortprogrammer/lazy-claudecode.git"
	},
	"homepage": "https://github.com/effortprogrammer/lazy-claudecode#readme",
	"bugs": {
		"url": "https://github.com/effortprogrammer/lazy-claudecode/issues"
	}
}
