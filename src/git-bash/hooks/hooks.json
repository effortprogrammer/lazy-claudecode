{
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "^Bash$",
				"hooks": [
					{
						"type": "command",
						"command": "node \"${PLUGIN_ROOT}/dist/cli.js\" hook pre-tool-use",
						"timeout": 5,
						"statusMessage": "(LazyClaude) Recommending Git Bash MCP"
					}
				]
			}
		],
		"PostCompact": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"${PLUGIN_ROOT}/dist/cli.js\" hook post-compact",
						"timeout": 5,
						"statusMessage": "(LazyClaude) Resetting Git Bash MCP Reminder"
					}
				]
			}
		]
	}
}
