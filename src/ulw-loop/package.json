{
	"name": "@effortprogrammer/lazy-claudecode-ulw-loop",
	"version": "4.13.0",
	"description": "Claude Code plugin: durable repo-native multi-goal orchestration with embedded success criteria and observable evidence audit.",
	"type": "module",
	"packageManager": "npm@11.12.1",
	"license": "MIT",
	"homepage": "https://github.com/effortprogrammer/lazy-claudecode-ulw-loop",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/effortprogrammer/lazy-claudecode-ulw-loop.git"
	},
	"bugs": {
		"url": "https://github.com/effortprogrammer/lazy-claudecode-ulw-loop/issues"
	},
	"keywords": [
		"claude-code",
		"claude-code-hook",
		"ulw-loop",
		"goal-mode",
		"orchestration",
		"evidence",
		"typescript"
	],
	"bin": {
		"lazy-claudecode-ulw-loop": "./dist/cli.js"
	},
	"files": ["dist", "hooks", "skills", "LICENSE", "NOTICE", "README.md", "CHANGELOG.md"],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest --run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"check": "tsc --noEmit && biome check . && npm run build"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/node": "^25.9.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
