{
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "^(apply_patch|Write|Edit|MultiEdit|multi_edit|write|edit|multiedit)$",
				"hooks": [
					{
						"type": "command",
						"command": "node \"${PLUGIN_ROOT}/dist/cli.js\" hook post-tool-use",
						"timeout": 60,
						"statusMessage": "(LazyClaude) Checking LSP Diagnostics"
					}
				]
			}
		]
	}
}
