{
	"name": "@effortprogrammer/lazy-claudecode-start-work-continuation",
	"version": "4.13.0",
	"description": "Claude Code Stop hook continuation injector for lazy-claudecode start-work plans.",
	"type": "module",
	"packageManager": "npm@11.12.1",
	"license": "MIT",
	"homepage": "https://github.com/effortprogrammer/lazy-claudecode-start-work-continuation",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/effortprogrammer/lazy-claudecode-start-work-continuation.git"
	},
	"bugs": {
		"url": "https://github.com/effortprogrammer/lazy-claudecode-start-work-continuation/issues"
	},
	"keywords": ["claude-code", "claude-code-hook", "start-work", "continuation", "hooks", "boulder"],
	"bin": {
		"lazy-claudecode-start-work-continuation": "./dist/cli.js"
	},
	"scripts": {
		"build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && bun build src/cli.ts --target node --format esm --outfile dist/cli.js",
		"test": "npm run build --silent && vitest --run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"check": "tsc --noEmit && biome check . && npm run build"
	},
	"files": ["dist", "directive.md", "hooks", "README.md", "LICENSE", "NOTICE"],
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/node": "^25.9.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
