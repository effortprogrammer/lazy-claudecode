{
	"mcpServers": {
		"grep_app": {
			"url": "https://mcp.grep.app"
		},
		"context7": {
			"url": "https://mcp.context7.com/mcp"
		},
		"codegraph": {
			"command": "node",
			"args": [
				"src/codegraph/serve.js"
			],
			"cwd": ".",
			"required": false
		},
		"git_bash": {
			"command": "node",
			"args": [
				"./src/git-bash/mcp-cli.js",
				"mcp"
			],
			"cwd": "."
		},
		"lsp": {
			"command": "node",
			"args": [
				"./src/lsp/daemon-cli.js",
				"mcp"
			],
			"cwd": "."
		}
	}
}
